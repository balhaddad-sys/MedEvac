{
  "rules": {
    "patients": {
      "$unit": {
        ".read": true,
        ".write": true,
        ".validate": "$unit.matches(/^[A-E]_(M|F)$/)",
        "$patient": {
          ".validate": "newData.hasChildren(['name', 'civil', 'ward', 'code', 'ts'])",
          "name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200" },
          "civil": { ".validate": "newData.isString() && newData.val().length <= 20" },
          "nat": { ".validate": "newData.isString() && newData.val().length <= 50" },
          "ward": { ".validate": "newData.isString() && newData.val().length <= 30" },
          "code": { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 4" },
          "notes": { ".validate": "newData.isString() && newData.val().length <= 500" },
          "ts": { ".validate": "newData.isNumber()" },
          "$other": { ".validate": false }
        }
      }
    },
    "pins": {
      ".read": true,
      ".write": true,
      "$pin": {
        ".validate": "$pin.matches(/^(A_M|A_F|B_M|B_F|C_M|C_F|D_M|D_F|E_M|E_F|ADMIN)$/) && newData.isString() && (newData.val().length == 64 || (newData.val().length >= 4 && newData.val().length <= 6))"
      }
    },
    "config": {
      ".read": true,
      ".write": false
    },
    "audit": {
      ".read": true,
      ".write": true,
      "$entry": {
        ".validate": "newData.hasChildren(['action', 'unit', 'ts']) && newData.child('action').isString() && newData.child('ts').isNumber()"
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
